{
  "name": "the-lab",
  "version": "1.0.0",
  "description": "A comprehensive multi-platform development boilerplate",
  "private": true,
  "workspaces": [
    "web",
    "apps/android"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
    "start": "npm run start --workspace=web",
    "lint": "npm run lint --workspace=web && npm run lint --workspace=apps/android",
    "test": "npm run test --workspace=web && npm run test --workspace=apps/android",
    "clean": "rm -rf node_modules web/node_modules apps/android/node_modules",
    "install-all": "npm install && npm install --workspace=web && npm install --workspace=apps/android",
    "setup": "npm run install-all"
  },
  "keywords": [
    "boilerplate",
    "nextjs",
    "react",
    "react-native",
    "swift",
    "swiftui",
    "typescript",
    "tailwind",
    "shadcn"
  ],
  "author": "Nick Sloggett",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/NickSloggett/The-Lab.git"
  },
  "bugs": {
    "url": "https://github.com/NickSloggett/The-Lab/issues"
  },
  "homepage": "https://github.com/NickSloggett/The-Lab#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}

